# Optional app labels
# MDPREFLIGHT_APP_NAME=MD Preflight ROP

# Google Maps (Geocoding + Places Nearby Search)
# Enable "Geocoding API" and "Places API" on the key.
# GOOGLE_MAPS_API_KEY=your-key-here
# or: MDPREFLIGHT_GOOGLE_MAPS_API_KEY=your-key-here

# Nearby search radius in meters (default 500)
# MDPREFLIGHT_GEO_RADIUS_M=500
