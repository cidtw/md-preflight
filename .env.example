# Optional app labels
# MDPREFLIGHT_APP_NAME=MD Preflight ROP

# Kakao Local REST API (address + category + keyword search)
# 1) https://developers.kakao.com 앱 생성
# 2) 앱 키 → REST API 키 복사
# 3) 플랫폼/동의 항목은 Local REST만 쓸 경우 최소 설정으로 가능
# Set real key only in .env.local or Vercel Project Env — never commit secrets.
# KAKAO_REST_API_KEY=your-rest-api-key-here
# or: MDPREFLIGHT_KAKAO_REST_API_KEY=your-rest-api-key-here

# Nearby search radius in meters (default 500, Kakao max 20000)
# MDPREFLIGHT_GEO_RADIUS_M=500

# SpaceXAI / xAI — 매출 하락 시나리오 AI 대응 방안 (서버 전용, 절대 프론트에 넣지 말 것)
# https://console.x.ai 에서 키 발급
# XAI_API_KEY=xai-...
# 또는: MDPREFLIGHT_XAI_API_KEY=xai-...
# 선택 모델 (기본 grok-4.5)
# XAI_MODEL=grok-4.5
