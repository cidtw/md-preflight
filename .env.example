# MD Preflight 환경변수 템플릿 — 실제 값은 절대 커밋하지 말 것 (.env.local 등은 .gitignore 처리됨)
# 아무것도 설정하지 않아도 서버는 완전히 동작한다: LLM은 결정론적 fallback 서사로,
# 이력 저장소는 인메모리로, 인증은 off 모드(비로그인)로 degrade된다.

# ── LLM 서술 (선택) ──
# 우선순위: OPENAI_API_KEY 존재 → OpenAI, 없고 ANTHROPIC_API_KEY 존재 → Anthropic, 둘 다 없으면 fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 모델 오버라이드 (선택 — 기본값은 각각 gpt-5.5 / claude-sonnet-5)
MDPREFLIGHT_OPENAI_MODEL=
MDPREFLIGHT_LLM_MODEL=

# ── 이력 저장소 (선택) — Neon/Postgres ──
# 둘 다 없으면 InMemoryHistoryStore로 fallback(프로세스 재시작 시 소실).
# preflight_runs(run_id 재조회용)와 run_history(이력 대시보드용) 둘 다 이 값을 공유한다.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── 인증 (선택) — Clerk ──
# 두 키가 모두 설정되면 auth_mode=clerk. 하나라도 비면 stub 경로로 넘어간다.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk 세션 토큰 azp(허용 origin) 검증용. 콤마 없이 줄마다/공백으로 나열 가능한 형식은
# 코드가 tuple로 파싱하므로 배포 환경(Vercel 등)의 환경변수 UI 규칙을 따를 것.
CLERK_AUTHORIZED_ORIGINS=

# Clerk가 설정되지 않았을 때 로컬 스텁 인증(X-MD-Preflight-User-Id 헤더/쿠키)을 명시적으로
# 켠다. 위조 가능한 경로이므로 로컬 데모·테스트 전용 — 프로덕션에서는 절대 true로 두지 말 것.
# 기본값은 false(auth_mode=off): 검수 자체는 그대로 동작하고 이력/대시보드만 401이 된다.
MDPREFLIGHT_ALLOW_STUB_AUTH=false

# ── 업로드 제한값 (선택 — 기본값 5MB / .csv,.xlsx) ──
# 프런트는 app/web/config_helpers.mjs를 통해 서버가 주입한 이 값을 그대로 읽는다.
MDPREFLIGHT_MAX_UPLOAD_BYTES=
MDPREFLIGHT_ALLOWED_EXTENSIONS=
